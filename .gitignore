# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# Build artifacts
*.egg-info/
*.egg
dist/
build/

# Virtual environment
.venv/

# Environment files
.env

# Testing
.pytest_cache/
htmlcov/
.coverage

# Linting/typing
.mypy_cache/
.ruff_cache/

# macOS
.DS_Store

# Ledger runtime data (auto-rebuilt by code)
ledger/index.json
ledger/records/*.json

# Per-experiment run artifacts (config snapshot + training logs +
# diagnostics + history). These accumulate over time and are
# regenerable from ledger/records/<run_id>.json once Phase Y
# experiment_provenance_hash composer is end-to-end validated. Adding
# here as part of α-5/100 (Phase α-1.1 hardening cycle, 2026-05-10).
ledger/runs/

# --- Ledger dormancy snapshot (2026-07-07, TRACKED archive) ---
# The LIVE ledger/{index.json,records/*.json,runs/} above stay ignored
# (auto-rebuilt runtime data). This one-time snapshot of the 186
# frozen-in-practice records + index is version-controlled so the
# 2026-03..2026-05 orchestrator-experiment provenance survives a re-clone.
# The patterns above are path-anchored and already do NOT match this
# subtree; these negations are explicit/defensive, not required today.
!ledger/archive/
!ledger/archive/**

# Phase R-17 F1 (2026-05-11): backtester producer-side ledger records land at
# `<manifest.parent.parent>/ledger/runs/` per readability:334 convention. For
# manifests in experiments/sweeps/, that resolves to experiments/ledger/runs/.
# Regenerable from backtest runs (artifact, not source).
experiments/ledger/runs/

# CI sibling-checkout scaffolding (Phase V.A.2): GitHub Actions
# workflows checkout sibling repos into _deps/<name>/. These are
# build-time artifacts, never committed. Keeps 'git status' clean
# if a developer mirrors CI locally via 'gh workflow run' or the
# equivalent manual checkout. Added by Phase V.A.0 audit (Agent 2 #1).
_deps/
